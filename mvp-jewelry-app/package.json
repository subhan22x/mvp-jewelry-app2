{
  "name": "pendant-mvp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "prisma migrate deploy && npm run db:seed && next start",
    "start:next": "next start",
    "start:render": "npm run start",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "styles": "node scripts/manage-styles.mjs",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "supabase:push": "node scripts/push-supabase-schema.mjs",
    "supabase:migrate-metadata": "node scripts/migrate-sqlite-to-supabase.mjs",
    "r2:migrate-generated": "node --experimental-strip-types scripts/migrate-generated-media-to-r2.mjs",
    "db:seed": "node scripts/seed-demo-user.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@google/genai": "^1.21.0",
    "@prisma/client": "^6.16.2",
    "fast-glob": "^3.3.2",
    "mime": "^4.1.0",
    "next": "14.2.31",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-international-phone": "^4.8.0",
    "sharp": "^0.34.5",
    "yaml": "^2.5.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@testing-library/user-event": "^14.5.1",
    "@types/node": "^22.8.1",
    "@types/react": "18.3.3",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "10.4.19",
    "jsdom": "^24.1.1",
    "pg": "^8.20.0",
    "postcss": "8.4.39",
    "prisma": "^6.16.2",
    "tailwindcss": "3.4.10",
    "ts-node": "^10.9.2",
    "tsx": "^4.16.2",
    "typescript": "5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.0.5"
  }
}
