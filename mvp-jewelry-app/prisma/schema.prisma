datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(cuid())
  storeName String
  createdAt DateTime @default(now())
  Requests  Request[]
}

model Request {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  productType    String   @default("name") // name | picture
  styleId        String
  text           String
  twoTone        Boolean  @default(false)
  primaryMetal   String
  secondaryMetal String?
  emblem         String   // none | crown | heart | spade | butterfly | moneybag
  uploadFileName String?
  Results        Result[]
  Videos         VideoGeneration[]
  QuoteRequests  QuoteRequest[]
}

model Result {
  id          String    @id @default(cuid())
  requestId   String
  request     Request   @relation(fields: [requestId], references: [id])
  variant     Int       // 1..2
  prompt      String
  imageUrl    String?
  modelId     String?
  status      String    @default("pending") // pending | succeeded | failed
  error       String?
  startedAt   DateTime?
  completedAt DateTime?
  durationMs  Int?
  createdAt   DateTime  @default(now())
  QuoteRequests QuoteRequest[]
}

model Lead {
  id        String   @id @default(cuid())
  requestId String?
  name      String
  phone     String
  email     String
  createdAt DateTime @default(now())
}

model VideoGeneration {
  id             String   @id @default(cuid())
  requestId      String
  request        Request  @relation(fields: [requestId], references: [id])
  sourceResultId String?
  sourceImageUrl String
  prompt         String
  videoUrl       String?
  remoteVideoUrl String?
  modelId        String?
  providerJobId  String?
  status         String   @default("pending") // pending | succeeded | failed
  error          String?
  startedAt      DateTime?
  completedAt    DateTime?
  durationMs     Int?
  createdAt      DateTime @default(now())
  QuoteRequests  QuoteRequest[]
}

model QuoteRequest {
  id               String           @id @default(cuid())
  requestId        String?
  request          Request?         @relation(fields: [requestId], references: [id])
  resultId         String?
  result           Result?          @relation(fields: [resultId], references: [id])
  videoId          String?
  video            VideoGeneration? @relation(fields: [videoId], references: [id])
  designedImageUrl String?
  videoUrl         String?
  generatedAt      DateTime?
  productType      String?
  styleId          String?
  text             String?
  twoTone          Boolean?
  primaryMetal     String?
  secondaryMetal   String?
  emblem           String?
  diamondQuality   String?
  customerName     String
  customerPhone    String
  customerEmail    String
  status           String           @default("pending") // pending | priced | sent | closed
  quotedPriceCents Int?
  quoteNotes       String?
  createdAt        DateTime         @default(now())
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}
