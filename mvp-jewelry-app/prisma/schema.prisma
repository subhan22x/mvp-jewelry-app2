datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(cuid())
  storeName String
  createdAt DateTime @default(now())
  Requests  Request[]
}

model Request {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  styleId        String
  text           String
  twoTone        Boolean  @default(false)
  primaryMetal   String
  secondaryMetal String?
  emblem         String   // none | crown | heart | spade | butterfly | moneybag
  Results        Result[]
}

model Result {
  id        String   @id @default(cuid())
  requestId String
  request   Request  @relation(fields: [requestId], references: [id])
  variant   Int      // 1..4
  prompt    String
  imageUrl  String
  createdAt DateTime @default(now())
}
