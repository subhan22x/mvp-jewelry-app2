DATABASE_URL="file:./dev.db"
# Optional explicit source used by SQLite-to-Supabase migration scripts.
# Defaults to prisma/dev.db.
SQLITE_SOURCE_DATABASE_URL=""
GOOGLE_API_KEY="your_google_api_key"
WAVESPEED_API_KEY="your_wavespeed_api_key"
VIDEO_ACCESS_CODE="ID8"
OWNER_ACCESS_CODE="ID8"
NAME_PROMPT_MODE="json"
VIDEO_DURATION_SECONDS=7
APP_BASE_URL="http://localhost:3000"
GENERATED_IMAGE_DIR="public/generated"

# Optional production media storage.
# If all required R2 vars are present, new generated images/videos are written to R2 instead of GENERATED_IMAGE_DIR.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="mvp-jewelry-media"
R2_ENDPOINT=""
R2_PUBLIC_BASE_URL=""
